# ─────────────────────────────────────────────
# ToyX — Environment Configuration
# Copy this file to .env and fill in values.
# ─────────────────────────────────────────────

# ── Database ─────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/toyx

# ── Session ─────────────────────────────────
# Generate with: openssl rand -hex 32
SESSION_SECRET=

# ── Application ──────────────────────────────
APP_BASE_URL=https://toyxchange.online
PORT=5000

# ── Email (Resend) ──────────────────────────
RESEND_API_KEY=re_...
FROM_EMAIL="ToyX <hello@toyxchange.online>"

# ── Image Storage (Cloudflare R2) ───────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=toyx-images
R2_PUBLIC_URL=https://images.toyxchange.online

# ── Authentication ──────────────────────────
# Google OAuth — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Facebook OAuth — https://developers.facebook.com/apps
ENABLE_FACEBOOK_AUTH=false
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# ── Location (Google Places) ────────────────
GOOGLE_MAPS_API_KEY=

# ── Payments (Paystack) ─────────────────────
PAYSTACK_SECRET_KEY=sk_...
PAYSTACK_MONTHLY_PLAN_CODE=PLN_qa2hymptm1v3pks
PAYSTACK_YEARLY_PLAN_CODE=PLN_6r1rrbz34iv7ct4
PAYSTACK_MONTHLY_AMOUNT=8900
PAYSTACK_YEARLY_AMOUNT=44900

# ── Error Monitoring (Sentry) ───────────────
SENTRY_DSN=https://...
SENTRY_ENVIRONMENT=production
VITE_SENTRY_DSN=https://...
VITE_SENTRY_ENVIRONMENT=production
VITE_ENABLE_SENTRY_DEBUG=false
